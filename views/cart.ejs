<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Your Cart</title>
    <%- include('partials/header') %>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
    <%- include('partials/navbar') %>
    
    <div class="container mt-5">
        <h1 class="mb-4 text-center">Your Cart</h1>
        <div id="cart-items" class="row g-4"></div>
        <div class="text-center mt-4">
            <a onclick="window.location.href='/services'" class="btn btn-primary">Back to Products</a>
        </div>
        <!-- Total Price Section -->
        <div class="text-center mt-4">
            <h3>Total: $<span id="total-price">0.00</span></h3>
            <a href="/checkout" class="btn btn-success mt-2">Proceed to Checkout</a>
        </div>
    </div>
    
    <%- include('partials/footer') %>

    <script>
        // Retrieve cart items from local storage
        const cart = JSON.parse(localStorage.getItem('cart')) || [];
        const cartItemsContainer = document.getElementById('cart-items');
        let totalPrice = 0;

        // Function to fetch product details from your products JSON
        function fetchProducts() {
            return fetch('/products.json') // Ensure this path is correct
                .then(response => response.json())
                .catch(err => console.error('Error fetching products:', err)); // Catch fetch errors
        }

        // Display cart items with images and prices
        fetchProducts().then(products => {
            if (cart.length === 0) {
                cartItemsContainer.innerHTML = `
                    <div class="col-12">
                        <p class="text-center text-muted">Your cart is empty. Add some products!</p>
                    </div>
                `;
            } else {
                cart.forEach(productId => {
                    const product = products.find(p => p.id === Number(productId));
                    if (product) {
                        totalPrice += product.price;
                        const item = `
                            <div class="col-md-4 col-lg-3">
                                <div class="card h-100">
                                    <img src="${product.image}" class="card-img-top" alt="${product.name}">
                                    <div class="card-body text-center">
                                        <h5 class="card-title">${product.name}</h5>
                                        <p class="card-text">$${(product.price || 0).toFixed(2)}</p>
                                    </div>
                                    <div class="card-footer text-center">
                                        <button class="btn btn-danger btn-sm" onclick="removeFromCart('${product.id}')">Remove</button>
                                    </div>
                                </div>
                            </div>
                        `;
                        cartItemsContainer.innerHTML += item;
                    }
                });
            }

            // Display total price
            document.getElementById('total-price').textContent = totalPrice.toFixed(2);
        });

        // Function to remove item from cart
        function removeFromCart(productId) {
            const updatedCart = cart.filter(id => id !== productId);
            localStorage.setItem('cart', JSON.stringify(updatedCart));
            location.reload(); // Reload page to reflect updated cart
        }
    </script>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
