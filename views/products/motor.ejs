<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Product List</title>
</head>
<body>
    <%- include('partials/navbar') %>
    <h1>Product List</h1>
    <ul>
        <% products.forEach(product => { %>
            <li>
                <strong><%= product.name %></strong> - $<%= product.price.toFixed(2) %> (Category: <%= product.category %>)
            </li>
        <% }); %>
    </ul>
    <%- include('partials/footer') %>
</body>
</html>
